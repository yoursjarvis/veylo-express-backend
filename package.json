{
  "name": "express-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc-alias -f -fe .js",
    "infra:up": "docker compose up -d postgres redis mailpit",
    "infra:down": "docker compose down",
    "setup:local": "npm run infra:up && npx prisma generate && npx prisma migrate dev",
    "format": "prettier . --write",
    "db:deploy": "npx prisma migrate deploy && npx prisma generate",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "seed:permissions": "tsx src/database/seeders/seed-permissions.ts",
    "seed:templates": "tsx src/scripts/seed-templates.ts",
    "seed:test": "tsx src/scripts/seed-test-data.ts",
    "db:seed": "tsx src/scripts/db-seed.ts",
    "start": "node dist/src/index.js",
    "worker:mail": "tsx src/workers/mail.worker.ts",
    "worker:mail:prod": "node dist/src/workers/mail.worker.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@better-auth/prisma-adapter": "^1.6.22",
    "@bull-board/api": "^8.0.1",
    "@bull-board/express": "^8.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.22",
    "bullmq": "^5.79.2",
    "bullmq-otel": "^1.3.1",
    "cors": "^2.8.6",
    "csv-parse": "^7.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "http-status-code": "^2.1.0",
    "ioredis": "^5.11.1",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^11.2.0",
    "resend": "^6.16.0",
    "sharp": "^0.35.2",
    "tsx": "^4.22.4",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "prisma": {
    "seed": "tsx src/scripts/seed-templates.ts"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.9.1",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "zod-to-ts": "^2.1.0"
  }
}
