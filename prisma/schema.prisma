// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(uuid(7)) @db.Uuid
  firstName           String    @map("first_name")
  lastName            String    @map("last_name")
  name                String    @map("name")
  email               String    @unique @map("email")
  emailVerified       Boolean   @default(false) @map("email_verified")
  image               String?   @map("image")
  isActive            Boolean   @default(true) @map("is_active")
  lastLoginAt         DateTime? @map("last_login_at")
  passwordChangedAt   DateTime? @map("password_changed_at")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  deletedAt           DateTime? @map("deleted_at")

  // Admin Plugin Fields
  role       String?   @default("user") @map("role")
  banned     Boolean?  @default(false) @map("banned")
  banReason  String?   @map("ban_reason")
  banExpires DateTime? @map("ban_expires")

  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  twoFactorEnabled Boolean? @map("two_factor_enabled")

  sessions         Session[]
  accounts         Account[]
  members          Member[]
  workspaceMembers WorkspaceMember[]
  invitations      Invitation[]
  twoFactors       TwoFactor[]

  @@index([email], map: "idx_users_email")
  @@index([isActive], map: "idx_users_is_active")
  @@index([deletedAt], map: "idx_users_deleted_at")
  @@index([lockedUntil], map: "idx_users_locked_until")
  @@map("users")
}

model Session {
  id                   String    @id @default(uuid(7)) @db.Uuid
  userId               String    @map("user_id") @db.Uuid
  token                String    @unique @map("token")
  expiresAt            DateTime  @map("expires_at")
  ipAddress            String?   @map("ip_address")
  userAgent            String?   @map("user_agent")
  deviceName           String?   @map("device_name")
  browser              String?   @map("browser")
  os                   String?   @map("os")
  country              String?   @map("country")
  location             String?   @map("location")
  lastActiveAt         DateTime? @map("last_active_at")
  revokedAt            DateTime? @map("revoked_at")
  activeOrganizationId String?   @map("active_organization_id")
  impersonatedBy       String?   @map("impersonated_by")
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_sessions_user_id")
  @@index([token], map: "idx_sessions_token")
  @@index([expiresAt], map: "idx_sessions_expires_at")
  @@index([revokedAt], map: "idx_sessions_revoked_at")
  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid(7)) @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz(6)
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz(6)
  scope                 String?   @map("scope")
  password              String?   @map("password")
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId], map: "uq_accounts_provider_account_id")
  @@index([userId], map: "idx_accounts_user_id")
  @@index([providerId], map: "idx_accounts_provider_id")
  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid(7)) @db.Uuid
  identifier String   @map("identifier")
  value      String   @map("value")
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([identifier], map: "idx_verifications_identifier")
  @@index([expiresAt], map: "idx_verifications_expires_at")
  @@map("verifications")
}

model Organization {
  id          String       @id @default(uuid(7)) @db.Uuid
  name        String
  slug        String?      @unique
  logo        String?
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  metadata    Json?
  members     Member[]
  invitations Invitation[]
  workspaces  Workspace[]

  @@map("organizations")
}

model Member {
  id             String   @id @default(uuid(7)) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           String
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("members")
}

model Workspace {
  id             String    @id @default(uuid(7)) @db.Uuid
  name           String
  slug           String    @unique
  icon           String?
  organizationId String    @map("organization_id") @db.Uuid
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      WorkspaceMember[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(uuid(7)) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  role        String   @default("member")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Invitation {
  id             String   @id @default(uuid(7)) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  email          String
  role           String?
  status         String
  expiresAt      DateTime @map("expires_at") @db.Timestamptz(6)
  inviterId      String   @map("inviter_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model Media {
  id                   String   @id @default(uuid(7)) @db.Uuid
  modelType            String   @map("model_type")
  modelId              String   @map("model_id") @db.Uuid
  collectionName       String   @map("collection_name")
  name                 String
  fileName             String   @map("file_name")
  mimeType             String?  @map("mime_type")
  disk                 String
  conversionsDisk      String?  @map("conversions_disk")
  size                 Int
  manipulations        Json?
  customProperties     Json?    @map("custom_properties")
  generatedConversions Json?    @map("generated_conversions")
  responsiveImages     Json?    @map("responsive_images")
  orderColumn          Int?     @map("order_column")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([modelType, modelId])
  @@map("media")
}

model TwoFactor {
  id          String  @id @default(uuid(7)) @db.Uuid
  secret      String
  backupCodes String  @map("backup_codes")
  userId      String  @map("user_id") @db.Uuid
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified    Boolean

  @@map("two_factors")
}
