// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(uuid(7)) @db.Uuid
  firstName           String    @map("first_name")
  lastName            String    @map("last_name")
  name                String    @map("name")
  email               String    @unique @map("email")
  emailVerified       Boolean   @default(false) @map("email_verified")
  image               String?   @map("image")
  isActive            Boolean   @default(true) @map("is_active")
  lastLoginAt         DateTime? @map("last_login_at")
  passwordChangedAt   DateTime? @map("password_changed_at")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  deletedAt           DateTime? @map("deleted_at")

  // Admin Plugin Fields
  role       String?   @default("user") @map("role")
  banned     Boolean?  @default(false) @map("banned")
  banReason  String?   @map("ban_reason")
  banExpires DateTime? @map("ban_expires")

  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  twoFactorEnabled Boolean? @map("two_factor_enabled")
  notificationPreferences String? @default("[]") @map("notification_preferences")

  sessions              Session[]
  accounts              Account[]
  members               Member[]
  workspaceMembers      WorkspaceMember[]
  projectMembers        ProjectMember[]
  invitations           Invitation[]
  twoFactors            TwoFactor[]
  createdTasks          Task[]               @relation("TaskCreator")
  assignedTasks         Task[]               @relation("TaskAssignee")
  reportedTasks         Task[]               @relation("TaskReporter")
  comments              Comment[]
  commentReactions      CommentReaction[]
  taskActivities        TaskActivity[]
  notificationsReceived Notification[]       @relation("NotificationRecipient")
  notificationsSent     Notification[]       @relation("NotificationSender")
  roleAssignments       UserRoleAssignment[]
  workLogs              WorkLog[]
  annotations           Annotation[]

  @@index([email], map: "idx_users_email")
  @@index([isActive], map: "idx_users_is_active")
  @@index([deletedAt], map: "idx_users_deleted_at")
  @@index([lockedUntil], map: "idx_users_locked_until")
  @@map("users")
}

model Session {
  id                   String    @id @default(uuid(7)) @db.Uuid
  userId               String    @map("user_id") @db.Uuid
  token                String    @unique @map("token")
  expiresAt            DateTime  @map("expires_at")
  ipAddress            String?   @map("ip_address")
  userAgent            String?   @map("user_agent")
  deviceName           String?   @map("device_name")
  browser              String?   @map("browser")
  os                   String?   @map("os")
  country              String?   @map("country")
  location             String?   @map("location")
  lastActiveAt         DateTime? @map("last_active_at")
  revokedAt            DateTime? @map("revoked_at")
  activeOrganizationId String?   @map("active_organization_id")
  impersonatedBy       String?   @map("impersonated_by")
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_sessions_user_id")
  @@index([token], map: "idx_sessions_token")
  @@index([expiresAt], map: "idx_sessions_expires_at")
  @@index([revokedAt], map: "idx_sessions_revoked_at")
  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid(7)) @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz(6)
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz(6)
  scope                 String?   @map("scope")
  password              String?   @map("password")
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId], map: "uq_accounts_provider_account_id")
  @@index([userId], map: "idx_accounts_user_id")
  @@index([providerId], map: "idx_accounts_provider_id")
  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid(7)) @db.Uuid
  identifier String   @map("identifier")
  value      String   @map("value")
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([identifier], map: "idx_verifications_identifier")
  @@index([expiresAt], map: "idx_verifications_expires_at")
  @@map("verifications")
}

model Organization {
  id                  String                  @id @default(uuid(7)) @db.Uuid
  name                String
  slug                String?                 @unique
  logo                String?
  createdAt           DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  metadata            Json?
  members             Member[]
  invitations         Invitation[]
  workspaces          Workspace[]
  projects            Project[]
  tasks               Task[]
  taskStatuses        TaskStatus[]
  sprints             Sprint[]
  comments            Comment[]
  taskActivities      TaskActivity[]
  notifications       Notification[]
  customFieldDefs     CustomFieldDefinition[]
  epics               Epic[]
  labels              Label[]
  milestones          Milestone[]
  roles               Role[]
  workflowTransitions WorkflowTransition[]
  checklistTemplates  ChecklistTemplate[]

  @@map("organizations")
}

model Member {
  id             String   @id @default(uuid(7)) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           String
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("members")
}

model Workspace {
  id             String    @id @default(uuid(7)) @db.Uuid
  name           String
  slug           String    @unique
  icon           String?
  organizationId String    @map("organization_id") @db.Uuid
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      WorkspaceMember[]
  projects     Project[]
  checklistTemplates  ChecklistTemplate[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(uuid(7)) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  role        String   @default("member")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Invitation {
  id             String   @id @default(uuid(7)) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  email          String
  role           String?
  status         String
  expiresAt      DateTime @map("expires_at") @db.Timestamptz(6)
  inviterId      String   @map("inviter_id") @db.Uuid
  projectIds     Json?    @map("project_ids")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model Media {
  id                   String   @id @default(uuid(7)) @db.Uuid
  modelType            String   @map("model_type")
  modelId              String   @map("model_id") @db.Uuid
  collectionName       String   @map("collection_name")
  name                 String
  fileName             String   @map("file_name")
  mimeType             String?  @map("mime_type")
  disk                 String
  conversionsDisk      String?  @map("conversions_disk")
  size                 Int
  manipulations        Json?
  customProperties     Json?    @map("custom_properties")
  generatedConversions Json?    @map("generated_conversions")
  responsiveImages     Json?    @map("responsive_images")
  orderColumn          Int?     @map("order_column")
  version              Int      @default(1)
  parentMediaId        String?  @map("parent_media_id") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  parentMedia          Media?   @relation("MediaVersions", fields: [parentMediaId], references: [id], onDelete: Cascade)
  versions             Media[]  @relation("MediaVersions")
  annotations          Annotation[]

  @@index([modelType, modelId])
  @@map("media")
}

model Annotation {
  id        String   @id @default(uuid(7)) @db.Uuid
  mediaId   String   @map("media_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  x         Float
  y         Float
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([mediaId])
  @@map("annotations")
}

model TwoFactor {
  id          String  @id @default(uuid(7)) @db.Uuid
  secret      String
  backupCodes String  @map("backup_codes")
  userId      String  @map("user_id") @db.Uuid
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified    Boolean

  @@map("two_factors")
}

model Project {
  id             String    @id @default(uuid(7)) @db.Uuid
  projectKey     String    @unique @map("project_key") @db.VarChar(10)
  title          String
  description    String?
  icon           String?
  template       String    @default("simple") // simple, kanban, scrum
  teamMode       String    @default("general") @map("team_mode") // software, general, hybrid
  workspaceId    String    @map("workspace_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  taskSequence   Int       @default(0) @map("task_sequence")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace           Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization        Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members             ProjectMember[]
  vault               Vault?
  tasks               Task[]
  taskStatuses        TaskStatus[]
  sprints             Sprint[]
  epics               Epic[]
  labels              Label[]
  milestones          Milestone[]
  customFields        CustomFieldDefinition[]
  slackWebhooks       SlackWebhook[]
  notifications       Notification[]
  workflowTransitions WorkflowTransition[]
  automationRules     AutomationRule[]

  @@index([organizationId], map: "idx_projects_org_id")
  @@index([workspaceId], map: "idx_projects_workspace_id")
  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(uuid(7)) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @default("member")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Vault {
  id        String   @id @default(uuid(7)) @db.Uuid
  projectId String   @unique @map("project_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  project  Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  services VaultService[]

  @@map("vaults")
}

model VaultService {
  id        String   @id @default(uuid(7)) @db.Uuid
  vaultId   String   @map("vault_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  vault Vault       @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  items VaultItem[]

  @@unique([vaultId, name])
  @@map("vault_services")
}

model VaultItem {
  id        String   @id @default(uuid(7)) @db.Uuid
  serviceId String   @map("service_id") @db.Uuid
  key       String
  value     String   @db.Text
  note      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  service VaultService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, key])
  @@map("vault_items")
}

model Task {
  id             String    @id @default(uuid(7)) @db.Uuid
  taskKey        String    @unique @map("task_key")
  title          String
  description    String?   @db.Text
  projectId      String    @map("project_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  epicId         String?   @map("epic_id") @db.Uuid // Epic / Initiative grouping
  milestoneId    String?   @map("milestone_id") @db.Uuid // Milestone link
  sprintId       String?   @map("sprint_id") @db.Uuid
  statusId       String    @map("status_id") @db.Uuid
  position       Float     @default(0) @map("position")
  type           String    @default("task") // task, bug, feature, story
  priority       String    @default("medium") // low, medium, high, urgent
  estimate       Float? // Story points or hours
  dueDate        DateTime? @map("due_date") @db.Timestamptz(6)
  creatorId      String    @map("creator_id") @db.Uuid
  assigneeId     String?   @map("assignee_id") @db.Uuid
  reporterId     String?   @map("reporter_id") @db.Uuid
  parentTaskId   String?   @map("parent_task_id") @db.Uuid
  customFields   Json?     @default("{}") @map("custom_fields") // JSONB storage
  isPrivate      Boolean   @default(false) @map("is_private")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  project               Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization          Organization     @relation(fields: [organizationId], references: [id])
  epic                  Epic?            @relation("EpicTasks", fields: [epicId], references: [id], onDelete: SetNull)
  milestone             Milestone?       @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  sprint                Sprint?          @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  status                TaskStatus       @relation(fields: [statusId], references: [id])
  creator               User             @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee              User?            @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporter              User?            @relation("TaskReporter", fields: [reporterId], references: [id])
  parentTask            Task?            @relation("Subtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks              Task[]           @relation("Subtasks")
  comments              Comment[]
  activityLogs          TaskActivity[]
  labels                TaskLabel[]
  blockedByDependencies TaskDependency[] @relation("BlockedTasks")
  blockingDependencies  TaskDependency[] @relation("BlockingTasks")
  notifications         Notification[]
  workLogs              WorkLog[]

  @@index([organizationId], map: "idx_tasks_org_id")
  @@index([projectId], map: "idx_tasks_project_id")
  @@index([epicId], map: "idx_tasks_epic_id")
  @@index([milestoneId], map: "idx_tasks_milestone_id")
  @@index([sprintId], map: "idx_tasks_sprint_id")
  @@index([statusId], map: "idx_tasks_status_id")
  @@index([assigneeId], map: "idx_tasks_assignee_id")
  @@index([parentTaskId], map: "idx_tasks_parent_task_id")
  @@index([deletedAt], map: "idx_tasks_deleted_at")
  @@map("tasks")
}

model TaskStatus {
  id             String   @id @default(uuid(7)) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String // e.g. "To Do", "In Progress", "Code Review"
  category       String // backlog, todo, in_progress, done
  order          Int      @default(0) // Order of columns on Kanban boards
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  project                 Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization            Organization         @relation(fields: [organizationId], references: [id])
  tasks                   Task[]
  workflowTransitionsFrom WorkflowTransition[] @relation("FromStatus")
  workflowTransitionsTo   WorkflowTransition[] @relation("ToStatus")

  @@unique([projectId, name])
  @@index([organizationId], map: "idx_task_statuses_org_id")
  @@map("task_statuses")
}

model Sprint {
  id             String    @id @default(uuid(7)) @db.Uuid
  projectId      String    @map("project_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String // e.g., "Sprint 1"
  goal           String?   @db.Text
  status         String    @default("planned") // planned, active, completed
  startDate      DateTime? @map("start_date") @db.Timestamptz(6)
  endDate        DateTime? @map("end_date") @db.Timestamptz(6)
  completedAt    DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])
  tasks        Task[]

  @@index([organizationId], map: "idx_sprints_org_id")
  @@index([projectId], map: "idx_sprints_project_id")
  @@map("sprints")
}

model CustomFieldDefinition {
  id             String   @id @default(uuid(7)) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String // e.g. "Client Approval"
  type           String // text, number, date, select, checkbox
  options        Json? // Array of options if type is select
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([projectId, name])
  @@index([organizationId], map: "idx_custom_field_definitions_org_id")
  @@map("custom_field_definitions")
}

model Comment {
  id             String   @id @default(uuid(7)) @db.Uuid
  taskId         String   @map("task_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  parentId       String?  @map("parent_id") @db.Uuid
  content        String   @db.Text
  isEdited       Boolean  @default(false) @map("is_edited")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  task         Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization      @relation(fields: [organizationId], references: [id])
  parent       Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Comment[]         @relation("CommentReplies")
  reactions    CommentReaction[]

  @@index([organizationId], map: "idx_comments_org_id")
  @@index([parentId], map: "idx_comments_parent_id")
  @@map("comments")
}

model CommentReaction {
  id        String   @id @default(uuid(7)) @db.Uuid
  commentId String   @map("comment_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String   @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji], map: "uq_comment_reactions_user_emoji")
  @@map("comment_reactions")
}

model TaskActivity {
  id             String   @id @default(uuid(7)) @db.Uuid
  taskId         String   @map("task_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  action         String // created, status_changed, assignee_changed, comment_added, etc.
  oldValue       String?  @db.Text
  newValue       String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  task         Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId], map: "idx_task_activities_org_id")
  @@index([taskId], map: "idx_task_activities_task_id")
  @@map("task_activities")
}

model SlackWebhook {
  id        String   @id @default(uuid(7)) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  url       String
  channel   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("slack_webhooks")
}

model Notification {
  id             String   @id @default(uuid(7)) @db.Uuid
  recipientId    String   @map("recipient_id") @db.Uuid
  senderId       String?  @map("sender_id") @db.Uuid
  taskId         String?  @map("task_id") @db.Uuid
  projectId      String?  @map("project_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  type           String // mention, assignment, status_change, comment, dependency
  title          String
  message        String
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  recipient    User         @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  sender       User?        @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)
  task         Task?        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId], map: "idx_notifications_org_id")
  @@index([recipientId])
  @@map("notifications")
}

model TaskDependency {
  id             String   @id @default(uuid(7)) @db.Uuid
  blockingTaskId String   @map("blocking_task_id") @db.Uuid
  blockedTaskId  String   @map("blocked_task_id") @db.Uuid
  dependencyType String   @default("blocks") // blocks
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  blockingTask Task @relation("BlockingTasks", fields: [blockingTaskId], references: [id], onDelete: Cascade)
  blockedTask  Task @relation("BlockedTasks", fields: [blockedTaskId], references: [id], onDelete: Cascade)

  @@unique([blockingTaskId, blockedTaskId, dependencyType])
  @@map("task_dependencies")
}

model Epic {
  id             String    @id @default(uuid(7)) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  projectId      String    @map("project_id") @db.Uuid
  title          String
  description    String?   @db.Text
  color          String    @default("#6366f1")
  startDate      DateTime? @map("start_date") @db.Timestamptz(6)
  endDate        DateTime? @map("end_date") @db.Timestamptz(6)
  status         String    @default("open") // open, in_progress, done
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks        Task[]       @relation("EpicTasks")

  @@index([projectId], map: "idx_epics_project_id")
  @@index([organizationId], map: "idx_epics_org_id")
  @@map("epics")
}

model ProjectTemplate {
  id          String   @id @default(uuid(7)) @db.Uuid
  name        String
  slug        String   @unique
  description String?  @db.Text
  icon        String?
  category    String // software, hr, marketing, finance, general
  isSystem    Boolean  @default(true) @map("is_system")
  config      Json // Full   configuration JSON
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("project_templates")
}

model Label {
  id             String   @id @default(uuid(7)) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  color          String // hex color
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])
  tasks        TaskLabel[]

  @@unique([projectId, name])
  @@index([organizationId], map: "idx_labels_org_id")
  @@map("labels")
}

model TaskLabel {
  taskId  String @map("task_id") @db.Uuid
  labelId String @map("label_id") @db.Uuid
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@map("task_labels")
}

model Milestone {
  id             String    @id @default(uuid(7)) @db.Uuid
  projectId      String    @map("project_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  title          String
  description    String?   @db.Text
  dueDate        DateTime? @map("due_date") @db.Timestamptz(6)
  isCompleted    Boolean   @default(false) @map("is_completed")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])
  tasks        Task[]

  @@index([projectId], map: "idx_milestones_project_id")
  @@index([organizationId], map: "idx_milestones_org_id")
  @@map("milestones")
}

model Permission {
  id          String   @id @default(uuid(7)) @db.Uuid
  resource    String
  action      String
  module      String   @default("PROJECT_MANAGEMENT")
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  roles RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model Role {
  id              String   @id @default(uuid(7)) @db.Uuid
  organizationId  String?  @map("organization_id") @db.Uuid
  name            String
  isSystemDefault Boolean  @default(false) @map("is_system_default")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization        Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions         RolePermission[]
  assignments         UserRoleAssignment[]
  workflowTransitions WorkflowTransition[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id        String @id @default(uuid(7)) @db.Uuid
  userId    String @map("user_id") @db.Uuid
  roleId    String @map("role_id") @db.Uuid
  scopeType String @map("scope_type") // e.g. ORGANIZATION, PROJECT
  scopeId   String @map("scope_id") @db.Uuid // ID of the organization or project

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, scopeType, scopeId])
  @@index([userId])
  @@index([scopeType, scopeId])
  @@map("user_role_assignments")
}

model WorkflowTransition {
  id             String   @id @default(uuid(7)) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  fromStatusId   String   @map("from_status_id") @db.Uuid
  toStatusId     String   @map("to_status_id") @db.Uuid
  requiredRoleId String?  @map("required_role_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])
  fromStatus   TaskStatus   @relation("FromStatus", fields: [fromStatusId], references: [id])
  toStatus     TaskStatus   @relation("ToStatus", fields: [toStatusId], references: [id])
  requiredRole Role?        @relation(fields: [requiredRoleId], references: [id])

  @@unique([projectId, fromStatusId, toStatusId])
  @@index([organizationId])
  @@map("workflow_transitions")
}

model AutomationRule {
  id          String   @id @default(uuid(7)) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  name        String
  trigger     String   // task_status_changed, subtasks_all_done
  triggerVal  String?  @map("trigger_val")
  action      String   // close_parent, assign_to_creator, etc.
  actionVal   String?  @map("action_val")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("automation_rules")
}

model WorkLog {
  id          String   @id @default(uuid(7)) @db.Uuid
  taskId      String   @map("task_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  hoursLogged Float    @map("hours_logged")
  loggedAt    DateTime @default(now()) @map("logged_at")
  description String?  @db.Text

  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@map("work_logs")
}

model ChecklistTemplate {
  id             String   @id @default(uuid(7)) @db.Uuid
  name           String
  description    String?  @db.Text
  items          Json     // Array of strings (checklist items / subtask titles)
  workspaceId    String   @map("workspace_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("checklist_templates")
}


